# ─── Server ─────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shopqa
DB_USER=shopqa_user
DB_PASSWORD=shopqa_pass

# ─── JWT ─────────────────────────────────────────────
JWT_SECRET=shopqa_super_secret_jwt_key_change_in_production_minimum_32_chars
JWT_REFRESH=shopqa_refresh_secret_key_change_in_production_minimum_32_chars
JWT_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Frontend URL (CORS) ──────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Email (for verification, optional) ──────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@shopqa.com
SMTP_PASS=your_smtp_password

# ─── File Upload ─────────────────────────────────────
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads/

# ─── Rate Limiting ────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
